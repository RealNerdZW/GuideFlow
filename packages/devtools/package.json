{
  "name": "@guideflow/devtools",
  "version": "0.1.0",
  "description": "Browser DevTools extension for GuideFlow.js — visual tour builder and flow inspector",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@guideflow/core": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "author": "John Mugabe (https://github.com/johnmugabe)",
  "homepage": "https://github.com/johnmugabe/GuideFlow#readme",
  "bugs": "https://github.com/johnmugabe/GuideFlow/issues"
}
