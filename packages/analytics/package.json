{
  "name": "@guideflow/analytics",
  "version": "0.1.1",
  "description": "Analytics, A/B testing, and event transport for GuideFlow.js",
  "keywords": ["guided-tour", "analytics", "product-tour", "guideflow"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealNerdZW/GuideFlow.git",
    "directory": "packages/analytics"
  },
  "homepage": "https://github.com/RealNerdZW/GuideFlow#readme",
  "bugs": "https://github.com/RealNerdZW/GuideFlow/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@guideflow/core": "workspace:*"
  },
  "devDependencies": {
    "@guideflow/core": "workspace:*",
    "happy-dom": "^13.6.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.1"
  }
}
