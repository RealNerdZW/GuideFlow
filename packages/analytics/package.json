{
  "name": "@guideflow/analytics",
  "version": "0.1.0",
  "description": "Analytics, A/B testing, and event transport for GuideFlow.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@guideflow/core": "workspace:*"
  },
  "devDependencies": {
    "@guideflow/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
