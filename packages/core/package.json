{
  "name": "@guideflow/core",
  "version": "0.1.2",
  "description": "GuideFlow core engine — framework-agnostic, zero dependencies",
  "keywords": ["guided-tour", "product-tour", "onboarding", "spotlight", "guideflow"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealNerdZW/GuideFlow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/RealNerdZW/GuideFlow#readme",
  "bugs": "https://github.com/RealNerdZW/GuideFlow/issues",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "import": "./dist/styles/index.css"
    },
    "./styles/*": {
      "import": "./dist/styles/*"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup && cp -r src/styles dist/styles",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist coverage .turbo",
    "size": "size-limit"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.2",
    "@types/node": "^20.11.20",
    "happy-dom": "^13.6.2",
    "size-limit": "^11.0.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "12 kB",
      "gzip": true
    }
  ]
}
