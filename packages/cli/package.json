{
  "name": "@guideflow/cli",
  "version": "0.1.2",
  "description": "CLI for GuideFlow.js — init, studio, export, and push flows",
  "keywords": ["guided-tour", "cli", "product-tour", "guideflow"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealNerdZW/GuideFlow.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/RealNerdZW/GuideFlow#readme",
  "bugs": "https://github.com/RealNerdZW/GuideFlow/issues",
  "type": "module",
  "bin": {
    "guideflow": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "vite": "^5.2.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
